#:import get_color_from_hex kivy.utils.get_color_from_hex

<ItemRow>:
    size_hint_y: None
    height: "72dp"
    radius: [16, 16, 16, 16]
    md_bg_color: get_color_from_hex('#FFFFFF')
    elevation: 0
    padding: ["16dp", "8dp", "8dp", "8dp"]

    MDBoxLayout:
        orientation: 'horizontal'
        spacing: "10dp"

        AnchorLayout:
            size_hint_x: None
            width: "24dp"
            anchor_x: "center"
            anchor_y: "center"
            MDIcon:
                icon: "food-outline"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#4E9773')
                adaptive_size: True

        MDBoxLayout:
            orientation: 'vertical'
            spacing: "2dp"
            pos_hint: {"center_y": .5}

            MDLabel:
                text: root.item_name
                font_style: "Body1"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#0E1B14')
                adaptive_height: True

            MDBoxLayout:
                orientation: 'horizontal'
                spacing: "4dp"
                adaptive_height: True

                AnchorLayout:
                    size_hint_x: None
                    width: "16dp"
                    anchor_x: "center"
                    anchor_y: "center"
                    MDIcon:
                        icon: "account-group-outline"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#4E9773')
                        font_size: "14sp"
                        adaptive_size: True

                MDLabel:
                    text: root.assigned_text
                    font_style: "Caption"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#4E9773')
                    adaptive_height: True

        Widget:

        MDLabel:
            text: root.price_text
            font_style: "Subtitle2"
            bold: True
            theme_text_color: "Custom"
            text_color: get_color_from_hex('#0E1B14')
            halign: "right"
            size_hint_x: None
            width: "80dp"
            pos_hint: {"center_y": .5}

        MDIconButton:
            icon: "account-edit-outline"
            theme_text_color: "Custom"
            icon_color: get_color_from_hex('#4E9773')
            on_release: root.do_assign()
            size_hint: None, None
            size: "36dp", "36dp"
            pos_hint: {"center_y": .5}

        MDIconButton:
            icon: "close"
            theme_text_color: "Custom"
            icon_color: get_color_from_hex('#94A3B8')
            on_release: root.do_delete()
            size_hint: None, None
            size: "36dp", "36dp"
            pos_hint: {"center_y": .5}
