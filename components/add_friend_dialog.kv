#:import get_color_from_hex kivy.utils.get_color_from_hex

<AddFriendDialog>:
    size_hint: None, None
    size: "360dp", "340dp"
    radius: [28, 28, 28, 28]
    md_bg_color: get_color_from_hex('#FFFFFF')
    elevation: 0
    padding: ["24dp", "24dp", "24dp", "24dp"]

    MDBoxLayout:
        orientation: 'vertical'
        spacing: "14dp"

        MDLabel:
            text: "👋"
            font_size: "48sp"
            halign: "center"
            size_hint_y: None
            height: "64dp"

        MDLabel:
            text: "Add a Friend"
            font_style: "H6"
            bold: True
            theme_text_color: "Custom"
            text_color: get_color_from_hex('#0E1B14')
            halign: "center"
            adaptive_height: True

        MDLabel:
            text: "Type their name below to invite them to split the bill with you!"
            font_style: "Body2"
            theme_text_color: "Custom"
            text_color: get_color_from_hex('#6B7280')
            halign: "center"
            adaptive_height: True

        MDCard:
            size_hint_y: None
            height: "52dp"
            radius: [26, 26, 26, 26]
            md_bg_color: get_color_from_hex('#F3FAF6')
            elevation: 0
            padding: ["16dp", "0dp", "16dp", "0dp"]

            MDBoxLayout:
                orientation: 'horizontal'
                spacing: "10dp"

                AnchorLayout:
                    size_hint_x: None
                    width: "24dp"
                    anchor_x: "center"
                    anchor_y: "center"
                    MDIcon:
                        icon: "magnify"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#4E9773')
                        adaptive_size: True

                MDTextField:
                    id: friend_name_input
                    hint_text: "Type friend's name..."
                    mode: "fill"
                    fill_color_normal: 0, 0, 0, 0
                    fill_color_focus: 0, 0, 0, 0
                    line_color_normal: 0, 0, 0, 0
                    line_color_focus: 0, 0, 0, 0
                    font_size: "16sp"

        MDCard:
            size_hint_y: None
            height: "52dp"
            radius: [26, 26, 26, 26]
            md_bg_color: get_color_from_hex('#50C878')
            elevation: 0
            ripple_behavior: True
            on_release: root.confirm_add()

            MDBoxLayout:
                orientation: 'horizontal'
                spacing: "8dp"
                padding: ["16dp", "0dp", "16dp", "0dp"]

                AnchorLayout:
                    size_hint_x: None
                    width: "24dp"
                    anchor_x: "center"
                    anchor_y: "center"
                    MDIcon:
                        icon: "account-plus"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#FFFFFF')
                        adaptive_size: True

                MDLabel:
                    text: "Add Friend"
                    font_style: "Subtitle1"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#FFFFFF')
                    halign: "center"
                    adaptive_height: True

        MDCard:
            size_hint_y: None
            height: "40dp"
            radius: [20, 20, 20, 20]
            md_bg_color: get_color_from_hex('#F3F4F6')
            elevation: 0
            ripple_behavior: True
            on_release: root.cancel()

            MDLabel:
                text: "Cancel"
                font_style: "Body2"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#4E9773')
                halign: "center"
                adaptive_height: True
