#:import get_color_from_hex kivy.utils.get_color_from_hex

<PersonToggleRow>:
    size_hint_y: None
    height: "56dp"
    radius: [16, 16, 16, 16]
    elevation: 0
    ripple_behavior: True
    padding: ["12dp", "0dp", "12dp", "0dp"]
    on_release: root.toggle()

    MDBoxLayout:
        orientation: 'horizontal'
        spacing: "12dp"

        MDCard:
            size_hint: None, None
            size: "36dp", "36dp"
            radius: [18, 18, 18, 18]
            md_bg_color: get_color_from_hex('#50C878')
            elevation: 0

            MDLabel:
                text: root.first_letter
                font_style: "Subtitle2"
                bold: True
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#FFFFFF')
                halign: "center"
                valign: "center"

        MDLabel:
            text: root.display_name
            font_style: "Body1"
            theme_text_color: "Custom"
            text_color: get_color_from_hex('#0E1B14')
            adaptive_height: True

        Widget:

        MDIcon:
            id: check_icon
            icon: "check-circle"
            theme_text_color: "Custom"
            text_color: get_color_from_hex('#50C878')
            size_hint_x: None
            width: "28dp"
            opacity: root.check_opacity
