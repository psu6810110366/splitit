#:import get_color_from_hex kivy.utils.get_color_from_hex

<ResultScreen>:
    MDFloatLayout:
        md_bg_color: get_color_from_hex('#F0FFF4')

        MDScrollView:
            pos_hint: {"top": 1}
            size_hint_y: 1

            MDBoxLayout:
                orientation: 'vertical'
                padding: ["20dp", "48dp", "20dp", "120dp"]
                spacing: "24dp"
                adaptive_height: True

                # Header
                MDBoxLayout:
                    orientation: 'horizontal'
                    adaptive_height: True
                    size_hint_y: None
                    height: "48dp"

                    MDCard:
                        size_hint: None, None
                        size: "40dp", "40dp"
                        radius: [20, 20, 20, 20]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.go_back()

                        MDIcon:
                            icon: "arrow-left"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0E1B14')
                            halign: "center"

                    Widget:

                    MDLabel:
                        text: "Split Summary 🎉"
                        font_style: "H6"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#0E1B14')
                        halign: "center"
                        size_hint_x: None
                        width: "200dp"

                    Widget:

                    MDCard:
                        size_hint: None, None
                        size: "40dp", "40dp"
                        radius: [20, 20, 20, 20]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.on_copy_clipboard()

                        MDIcon:
                            icon: "share-variant"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0E1B14')
                            halign: "center"

                # QR Code Container (Hidden by default, shown via python if promptpay exists)
                MDBoxLayout:
                    id: qr_container
                    orientation: 'vertical'
                    size_hint_y: None
                    height: "0dp"
                    opacity: 0
                    spacing: "12dp"
                    padding: ["0dp", "8dp", "0dp", "24dp"]

                    MDCard:
                        size_hint: None, None
                        size: "200dp", "200dp"
                        pos_hint: {"center_x": .5}
                        elevation: 0
                        radius: [16, 16, 16, 16]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        padding: ["8dp", "8dp", "8dp", "8dp"]

                        Image:
                            id: qr_image
                            source: ""
                            allow_stretch: True
                            keep_ratio: True

                    MDLabel:
                        id: qr_info_label
                        text: ""
                        font_style: "Subtitle2"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#0E1B14')
                        halign: "center"
                        adaptive_height: True

                # "Items Ordered" heading
                MDLabel:
                    id: items_heading_label
                    text: "Items Ordered"
                    font_style: "H6"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0E1B14')
                    adaptive_height: True
                    halign: "center"

                # Items list container
                MDBoxLayout:
                    id: items_list_container
                    orientation: 'vertical'
                    adaptive_height: True
                    spacing: "8dp"

                # "Who pays what?" heading
                MDLabel:
                    text: "Who pays what?"
                    font_style: "H4"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0E1B14')
                    adaptive_height: True
                    halign: "center"

                # Participants list
                MDBoxLayout:
                    id: participants_list
                    orientation: 'vertical'
                    adaptive_height: True
                    spacing: "12dp"

        # Bottom buttons
        MDBoxLayout:
            orientation: 'vertical'
            size_hint: 1, None
            height: "136dp"
            pos_hint: {"bottom": 1, "x": 0}
            md_bg_color: get_color_from_hex('#F0FFF4')
            padding: ["20dp", "8dp", "20dp", "8dp"]
            spacing: "8dp"

            MDCard:
                size_hint_y: None
                height: "56dp"
                radius: [28, 28, 28, 28]
                md_bg_color: get_color_from_hex('#50C878')
                elevation: 0
                ripple_behavior: True
                on_release: root.on_copy_clipboard()

                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "8dp"
                    padding: ["16dp", "0dp", "16dp", "0dp"]

                    MDIcon:
                        icon: "content-copy"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#FFFFFF')
                        size_hint_x: None
                        width: "24dp"

                    MDLabel:
                        text: "Copy to Clipboard"
                        font_style: "Subtitle1"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#FFFFFF')
                        halign: "center"
                        adaptive_height: True

            MDCard:
                size_hint_y: None
                height: "56dp"
                radius: [28, 28, 28, 28]
                md_bg_color: get_color_from_hex('#FECDD3')
                elevation: 0
                ripple_behavior: True
                on_release: root.go_home()

                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "8dp"
                    padding: ["16dp", "0dp", "16dp", "0dp"]

                    MDIcon:
                        icon: "home-outline"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#BE123C')
                        size_hint_x: None
                        width: "24dp"

                    MDLabel:
                        text: "Back to Home"
                        font_style: "Subtitle1"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#BE123C')
                        halign: "center"
                        adaptive_height: True
