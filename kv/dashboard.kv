#:import get_color_from_hex kivy.utils.get_color_from_hex

<DashboardScreen>:
    MDFloatLayout:
        md_bg_color: get_color_from_hex('#FCF9F8')
        
        MDScrollView:
            pos_hint: {"top": 1}
            size_hint_y: 1
            
            MDBoxLayout:
                orientation: 'vertical'
                padding: ["24dp", "48dp", "24dp", "120dp"]
                spacing: "32dp"
                adaptive_height: True

                # Simple header
                MDBoxLayout:
                    orientation: 'horizontal'
                    adaptive_height: True
                    size_hint_y: None
                    height: "40dp"
                    
                    MDLabel:
                        text: "SplitIt 💸"
                        font_style: "H5"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#0F172A')
                        
                    Widget:
                        
                    MDCard:
                        size_hint: None, None
                        size: "40dp", "40dp" 
                        radius: [20, 20, 20, 20]
                        md_bg_color: get_color_from_hex('#FFF0EB')
                        
                        MDLabel:
                            text: "👩‍💼"
                            font_size: "24sp"
                            halign: "center"
                            valign: "center"

                # Hero section
                MDCard:
                    size_hint_y: None
                    height: "200dp"
                    radius: [32, 32, 32, 32]
                    md_bg_color: get_color_from_hex('#FFEDD5')
                    padding: ["25dp", "25dp", "25dp", "25dp"]
                    elevation: 0
                    
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: "24dp"
                        
                        MDLabel:
                            text: "Ready to split\nthe bill?"
                            font_style: "H4"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            adaptive_height: True
                        
                        MDCard:
                            size_hint_x: 1
                            size_hint_y: None
                            height: "48dp"
                            radius: [24, 24, 24, 24]
                            md_bg_color: get_color_from_hex('#F45925')
                            elevation: 0
                            ripple_behavior: True
                            on_release: root.go_to_new_split()
                            
                            MDLabel:
                                text: "Create New Bill"
                                font_style: "Subtitle2"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: get_color_from_hex('#FFFFFF')
                                halign: "center"
                                valign: "center"

                # Action buttons
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "16dp"
                    adaptive_height: True
                    size_hint_y: None
                    height: "102dp"
                    
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        size_hint_y: None
                        height: "102dp"
                        radius: [24, 24, 24, 24]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        padding: ["17dp", "17dp", "17dp", "17dp"]
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.go_to_scan()
                        
                        MDIcon:
                            icon: "camera-outline"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#16A34A')
                            size_hint_y: None
                            height: "40dp"
                                
                        MDLabel:
                            text: "Scan Receipt"
                            font_style: "Subtitle2"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            adaptive_height: True
                            
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        size_hint_y: None
                        height: "102dp"
                        radius: [24, 24, 24, 24]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        padding: ["17dp", "17dp", "17dp", "17dp"]
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.go_to_add_friend()
                        
                        MDIcon:
                            icon: "account-multiple-plus-outline"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#2563EB')
                            size_hint_y: None
                            height: "40dp"
                                
                        MDLabel:
                            text: "Add Friend"
                            font_style: "Subtitle2"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            adaptive_height: True

                # Balance summary
                MDLabel:
                    text: "Balance Summary"
                    font_style: "Subtitle1"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0F172A')
                    adaptive_height: True
                    
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "16dp"
                    adaptive_height: True
                    size_hint_y: None
                    height: "142dp"
                    
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        padding: ["21dp", "21dp", "21dp", "21dp"]
                        size_hint_y: None
                        height: "142dp"
                        radius: [32, 32, 32, 32]
                        md_bg_color: get_color_from_hex('#FFF1F2')
                        elevation: 0
                        
                        MDLabel:
                            text: "YOU OWE"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#FB7185')
                            font_style: "Caption"
                            bold: True
                            adaptive_height: True
                            
                        MDLabel:
                            text: "฿500"
                            theme_text_color: "Custom" 
                            text_color: get_color_from_hex('#E11D48')
                            font_style: "H5"
                            bold: True
                            adaptive_height: True
                    
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        padding: ["21dp", "21dp", "21dp", "21dp"]
                        size_hint_y: None
                        height: "142dp"
                        radius: [32, 32, 32, 32]
                        md_bg_color: get_color_from_hex('#F0F9FF')
                        elevation: 0
                        
                        MDLabel:
                            text: "OWED TO YOU"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#38BDF8')
                            font_style: "Caption"
                            bold: True
                            adaptive_height: True
                            
                        MDLabel:
                            text: "฿725"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0284C7')
                            font_style: "H5"
                            bold: True 
                            adaptive_height: True

                # Recent splits
                MDLabel:
                    text: "Recent Splits"
                    font_style: "Subtitle1"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0F172A')
                    adaptive_height: True

        # Bottom navigation
        BottomNav:
            active_tab: 'home'
