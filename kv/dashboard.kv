#:import get_color_from_hex kivy.utils.get_color_from_hex

# ── RecycleView item widget สำหรับแต่ละบิลใน Dashboard ──────────────────────
<BillCardItem>:
    size_hint_y: None
    height: "72dp"
    radius: [20, 20, 20, 20]
    md_bg_color: get_color_from_hex('#FFFFFF')
    elevation: 0
    padding: ["16dp", "0dp", "16dp", "0dp"]
    ripple_behavior: True
    on_release: app.root.get_screen('dashboard').on_bill_selected(root.bill_id)

    MDBoxLayout:
        orientation: 'horizontal'
        spacing: "12dp"

        # Emoji avatar
        MDLabel:
            text: root.emoji
            font_size: "28sp"
            size_hint_x: None
            width: "44dp"
            halign: "center"
            valign: "center"

        # Title + date
        MDBoxLayout:
            orientation: 'vertical'
            spacing: "2dp"

            MDLabel:
                text: root.title
                font_style: "Subtitle2"
                bold: True
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#0F172A')
                adaptive_height: True

            MDLabel:
                text: root.date_label
                font_style: "Caption"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#94A3B8')
                adaptive_height: True

        Widget:

        # Amount + status
        MDBoxLayout:
            orientation: 'vertical'
            size_hint_x: None
            width: "110dp"
            spacing: "2dp"

            MDLabel:
                text: root.amount_label
                font_style: "Subtitle2"
                bold: True
                halign: "right"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#0F172A')
                adaptive_height: True

            MDLabel:
                text: root.status_label
                font_style: "Caption"
                bold: True
                halign: "right"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#16A34A') if root.status_type == 'owed' else get_color_from_hex('#E11D48')
                adaptive_height: True

<DashboardScreen>:
    MDFloatLayout:
        md_bg_color: get_color_from_hex('#FCF9F8')
        
        MDScrollView:
            pos_hint: {"top": 1}
            size_hint_y: 1
            
            MDBoxLayout:
                orientation: 'vertical'
                padding: ["24dp", "48dp", "24dp", "120dp"]
                spacing: "32dp"
                adaptive_height: True

                # Simple header
                MDBoxLayout:
                    orientation: 'horizontal'
                    adaptive_height: True
                    size_hint_y: None
                    height: "40dp"
                    
                    MDLabel:
                        text: "SplitIt 💸"
                        font_style: "H5"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#0F172A')
                        
                    Widget:
                        
                    MDCard:
                        size_hint: None, None
                        size: "40dp", "40dp" 
                        radius: [20, 20, 20, 20]
                        md_bg_color: get_color_from_hex('#FFF0EB')
                        
                        MDLabel:
                            text: "👩‍💼"
                            font_size: "24sp"
                            halign: "center"
                            valign: "center"

                # Hero section
                MDCard:
                    size_hint_y: None
                    height: "200dp"
                    radius: [32, 32, 32, 32]
                    md_bg_color: get_color_from_hex('#FFEDD5')
                    padding: ["25dp", "25dp", "25dp", "25dp"]
                    elevation: 0
                    
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: "24dp"
                        
                        MDLabel:
                            text: "Ready to split\nthe bill?"
                            font_style: "H4"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            adaptive_height: True
                        
                        MDCard:
                            size_hint_x: 1
                            size_hint_y: None
                            height: "48dp"
                            radius: [24, 24, 24, 24]
                            md_bg_color: get_color_from_hex('#F45925')
                            elevation: 0
                            ripple_behavior: True
                            on_release: root.go_to_new_split()
                            
                            MDLabel:
                                text: "Create New Bill"
                                font_style: "Subtitle2"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: get_color_from_hex('#FFFFFF')
                                halign: "center"
                                valign: "center"

                # Action buttons
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "16dp"
                    adaptive_height: True
                    size_hint_y: None
                    height: "102dp"
                    
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        size_hint_y: None
                        height: "102dp"
                        radius: [24, 24, 24, 24]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        padding: ["17dp", "17dp", "17dp", "17dp"]
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.go_to_scan()
                        
                        MDIcon:
                            icon: "camera-outline"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#16A34A')
                            size_hint_y: None
                            height: "40dp"
                                
                        MDLabel:
                            text: "Scan Receipt"
                            font_style: "Subtitle2"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            adaptive_height: True
                            
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        size_hint_y: None
                        height: "102dp"
                        radius: [24, 24, 24, 24]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        padding: ["17dp", "17dp", "17dp", "17dp"]
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.go_to_add_friend()
                        
                        MDIcon:
                            icon: "account-multiple-plus-outline"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#2563EB')
                            size_hint_y: None
                            height: "40dp"
                                
                        MDLabel:
                            text: "Add Friend"
                            font_style: "Subtitle2"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            adaptive_height: True

                # Balance summary
                MDLabel:
                    text: "Balance Summary"
                    font_style: "Subtitle1"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0F172A')
                    adaptive_height: True
                    
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "16dp"
                    adaptive_height: True
                    size_hint_y: None
                    height: "142dp"
                    
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        padding: ["21dp", "21dp", "21dp", "21dp"]
                        size_hint_y: None
                        height: "142dp"
                        radius: [32, 32, 32, 32]
                        md_bg_color: get_color_from_hex('#FFF1F2')
                        elevation: 0
                        
                        MDLabel:
                            text: "YOU OWE"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#FB7185')
                            font_style: "Caption"
                            bold: True
                            adaptive_height: True
                            
                        MDLabel:
                            text: "฿500"
                            theme_text_color: "Custom" 
                            text_color: get_color_from_hex('#E11D48')
                            font_style: "H5"
                            bold: True
                            adaptive_height: True
                    
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        padding: ["21dp", "21dp", "21dp", "21dp"]
                        size_hint_y: None
                        height: "142dp"
                        radius: [32, 32, 32, 32]
                        md_bg_color: get_color_from_hex('#F0F9FF')
                        elevation: 0
                        
                        MDLabel:
                            text: "OWED TO YOU"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#38BDF8')
                            font_style: "Caption"
                            bold: True
                            adaptive_height: True
                            
                        MDLabel:
                            text: "฿725"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0284C7')
                            font_style: "H5"
                            bold: True 
                            adaptive_height: True

                # Recent splits
                MDLabel:
                    text: "Recent Splits"
                    font_style: "Subtitle1"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0F172A')
                    adaptive_height: True

                # Empty state — แสดงเมื่อยังไม่มีบิล
                MDLabel:
                    text: "ยังไม่มีบิล — กด Scan หรือ Create New Bill เพื่อเริ่ม!"
                    font_style: "Caption"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#BDBDBD')
                    halign: "center"
                    adaptive_height: True
                    opacity: 1 if len(root.recent_splits) == 0 else 0
                    size_hint_y: None
                    height: "40dp" if len(root.recent_splits) == 0 else "0dp"

                # Dynamic Bill List
                RecycleView:
                    id: recent_splits_rv
                    data: root.recent_splits
                    viewclass: "BillCardItem"
                    size_hint_y: None
                    height: rv_layout.minimum_height

                    RecycleBoxLayout:
                        id: rv_layout
                        orientation: "vertical"
                        spacing: "10dp"
                        padding: ["0dp", "0dp", "0dp", "0dp"]
                        default_size: None, "70dp"
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height

        # Bottom navigation component
        BottomNav:
            active_tab: 'home'
