#:import get_color_from_hex kivy.utils.get_color_from_hex

# --- BillCardItem: Reusable widget for each bill row in RecycleView ---
<BillCardItem@MDCard>:
    title: ""
    amount_label: ""
    date_label: ""
    status_color: "#00C853"
    is_done: False

    size_hint_y: None
    height: "70dp"
    padding: ["15dp", "10dp", "15dp", "10dp"]
    radius: [16, 16, 16, 16]
    md_bg_color: 1, 1, 1, 1
    elevation: 0

    MDBoxLayout:
        orientation: "horizontal"
        spacing: "15dp"

        # Status Dot
        MDCard:
            size_hint: None, None
            size: "45dp", "45dp"
            radius: [12, 12, 12, 12]
            md_bg_color: get_color_from_hex(root.status_color) if root.is_done else get_color_from_hex('#FFF0F0')
            pos_hint: {"center_y": .5}

            MDIcon:
                icon: "check-circle-outline" if root.is_done else "clock-outline"
                theme_text_color: "Custom"
                text_color: get_color_from_hex(root.status_color)
                pos_hint: {"center_x": .5, "center_y": .5}

        # Title + Date
        MDBoxLayout:
            orientation: "vertical"
            pos_hint: {"center_y": .5}

            MDLabel:
                text: root.title
                font_style: "Subtitle2"
                bold: True
                shorten: True
                shorten_from: "right"

            MDLabel:
                text: root.date_label
                font_style: "Caption"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#757575')

        # Amount
        MDLabel:
            text: root.amount_label
            font_style: "Subtitle2"
            bold: True
            theme_text_color: "Custom"
            text_color: get_color_from_hex(root.status_color)
            halign: "right"
            pos_hint: {"center_y": .5}

<DashboardScreen>:
    # Main Base Layout with Light background
    MDFloatLayout:
        md_bg_color: get_color_from_hex('#F8F9FA')
        
        # --- SCROLLABLE CONTENT ---
        MDScrollView:
            pos_hint: {"top": 1}
            # Leave space at the bottom for the floating navigation bar
            size_hint_y: 1
            
            MDBoxLayout:
                orientation: 'vertical'
                padding: ["20dp", "40dp", "20dp", "100dp"] # Padding bottom 100dp avoids hiding behind nav bar
                spacing: "24dp"
                adaptive_height: True

                # 1. HEADER (Title & Profile)
                MDBoxLayout:
                    orientation: 'horizontal'
                    adaptive_height: True
                    
                    MDLabel:
                        text: "SplitIt \U0001F4B8"
                        font_style: "H5"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#1A1A1A')
                        valign: "center"
                        size_hint_y: None
                        height: "40dp"
                        
                    # Profile Picture placeholder
                    FitImage:
                        source: "assets/profile.jpg"
                        size_hint: None, None
                        size: "40dp", "40dp"
                        radius: [20, 20, 20, 20]

                # 2. MAIN BANNER CARD
                # Using a dark purple/navy background to simulate the dark gradient card
                MDCard:
                    orientation: "vertical"
                    size_hint_y: None
                    height: "180dp"
                    radius: [24, 24, 24, 24]
                    md_bg_color: get_color_from_hex('#1F1A30')
                    padding: "20dp"
                    elevation: 3
                    
                    MDLabel:
                        text: "DASHBOARD"
                        font_style: "Overline"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#9E9E9E')
                        adaptive_height: True
                        
                    MDLabel:
                        text: "Ready to split\nthe bill?"
                        font_style: "H4"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1
                        valign: "center"
                        
                    # Orange gradient Button (Custom Card acting as button)
                    MDCard:
                        size_hint: None, None
                        size: "160dp", "45dp"
                        radius: [22, 22, 22, 22]
                        md_bg_color: get_color_from_hex('#FF6B00') # Vibrant Orange
                        elevation: 1
                        ripple_behavior: True
                        on_release: root.go_to_new_split()
                        
                        MDRelativeLayout:
                            MDLabel:
                                text: "Create New Bill"
                                font_style: "Subtitle2"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 1, 1, 1, 1
                                halign: "center"
                                valign: "center"

                # 3. ACTION BUTTONS (Scan & Add Friend)
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "15dp"
                    adaptive_height: True
                    
                    # Action 1: Scan Receipt
                    MDCard:
                        orientation: "vertical"
                        size_hint_y: None
                        height: "100dp"
                        radius: [20, 20, 20, 20]
                        md_bg_color: 1, 1, 1, 1
                        padding: "15dp"
                        elevation: 1
                        ripple_behavior: True
                        on_release: root.go_to_scan()
                        
                        MDIcon:
                            icon: "camera-outline"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#1F1A30')
                            font_size: "32sp"
                            pos_hint: {"center_x": .5}
                            
                        MDLabel:
                            text: "Scan\nReceipt"
                            font_style: "Caption"
                            bold: True
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#1F1A30')
                            
                    # Action 2: Add Friend
                    MDCard:
                        orientation: "vertical"
                        size_hint_y: None
                        height: "100dp"
                        radius: [20, 20, 20, 20]
                        md_bg_color: 1, 1, 1, 1
                        padding: "15dp"
                        elevation: 1
                        ripple_behavior: True
                        on_release: root.go_to_add_friend()
                        
                        MDIcon:
                            icon: "account-multiple-plus-outline"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#1F1A30')
                            font_size: "32sp"
                            pos_hint: {"center_x": .5}
                            
                        MDLabel:
                            text: "Add\nFriend"
                            font_style: "Caption"
                            bold: True
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#1F1A30')

                # 4. BALANCE SUMMARY SECION
                MDLabel:
                    text: "Balance Summary"
                    font_style: "Subtitle1"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#1A1A1A')
                    adaptive_height: True
                    
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "15dp"
                    adaptive_height: True
                    
                    # YOU OWE (Pinkish)
                    MDCard:
                        orientation: "vertical"
                        padding: "15dp"
                        size_hint_y: None
                        height: "90dp"
                        radius: [16, 16, 16, 16]
                        md_bg_color: get_color_from_hex('#FFF0F0') # Soft pink
                        elevation: 0
                        
                        MDLabel:
                            text: "YOU OWE"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#FF5252')
                            font_style: "Caption"
                            bold: True
                        MDLabel:
                            text: f"\u0E3F{root.total_owed:.2f}"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#1A1A1A')
                            font_style: "H6"
                            bold: True
                            
                    # OWED TO YOU (Light Blue)
                    MDCard:
                        orientation: "vertical"
                        padding: "15dp"
                        size_hint_y: None
                        height: "90dp"
                        radius: [16, 16, 16, 16]
                        md_bg_color: get_color_from_hex('#F0F8FF') # Soft blue
                        elevation: 0
                        
                        MDLabel:
                            text: "OWED TO YOU"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#2196F3')
                            font_style: "Caption"
                            bold: True
                        MDLabel:
                            text: f"\u0E3F{root.total_owe_me:.2f}"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#1A1A1A')
                            font_style: "H6"
                            bold: True

                # 5. RECENT SPLITS TITLE
                MDLabel:
                    text: "Recent Splits"
                    font_style: "Subtitle1"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#1A1A1A')
                    adaptive_height: True

                # Empty state — แสดงเมื่อยังไม่มีบิล
                MDLabel:
                    text: "ยังไม่มีบิล — กด Scan หรือ Create New Bill เพื่อเริ่ม!"
                    font_style: "Caption"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#BDBDBD')
                    halign: "center"
                    adaptive_height: True
                    opacity: 1 if len(root.recent_splits) == 0 else 0
                    size_hint_y: None
                    height: "40dp" if len(root.recent_splits) == 0 else "0dp"

                # Dynamic Bill List
                RecycleView:
                    id: recent_splits_rv
                    data: root.recent_splits
                    viewclass: "BillCardItem"
                    size_hint_y: None
                    height: rv_layout.minimum_height  # bind ไปที่ layout ข้างใน

                    RecycleBoxLayout:
                        id: rv_layout
                        orientation: "vertical"
                        spacing: "10dp"
                        padding: ["0dp", "0dp", "0dp", "0dp"]
                        default_size: None, "70dp"
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height

        # --- FLOATING BOTTOM NAVBAR PILL ---
        # Positioned right over the scrolling content
        MDCard:
            size_hint: None, None
            size: "240dp", "60dp"
            radius: [30, 30, 30, 30]
            md_bg_color: get_color_from_hex('#1A1A1A') # Black pill
            pos_hint: {"center_x": .5, "y": .03}
            elevation: 4
            padding: "20dp"
            
            MDBoxLayout:
                orientation: 'horizontal'
                
                # Nav 1: Dashboard (Active)
                MDIconButton:
                    icon: "home"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#FFFFFF')
                    pos_hint: {"center_y": .5}
                    
                Widget:
                    
                # Nav 2: Friends
                MDIconButton:
                    icon: "account-multiple"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#757575')
                    pos_hint: {"center_y": .5}
                    icon_size: "24sp"
                    on_release: root.go_to_friends()
                    
                Widget:
                
                # Nav 3: Camera
                MDIconButton:
                    icon: "camera-iris"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#757575')
                    pos_hint: {"center_y": .5}
                    on_release: root.go_to_scan()
