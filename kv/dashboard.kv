#:import get_color_from_hex kivy.utils.get_color_from_hex

# --- RecentSplitItem: Modern split item card for RecycleView ---
<RecentSplitItem@MDCard>:
    title: ""
    amount_label: ""
    date_label: ""
    status_label: ""
    status_type: "" # "owed" or "owe"  
    emoji: "🍽️"

    size_hint_y: None
    height: "80dp"
    padding: ["20dp", "15dp", "20dp", "15dp"]
    radius: [24, 24, 24, 24]
    md_bg_color: get_color_from_hex('#FFFFFF')
    elevation: 1

    MDBoxLayout:
        orientation: "horizontal"
        spacing: "16dp"
        
        # Emoji Avatar
        MDCard:
            size_hint: None, None
            size: "48dp", "48dp"
            radius: [24, 24, 24, 24]
            md_bg_color: get_color_from_hex('#FFF7ED')
            pos_hint: {"center_y": .5}

            MDLabel:
                text: root.emoji
                font_size: "24sp"
                halign: "center"
                valign: "center"

        # Title + Date
        MDBoxLayout:
            orientation: "vertical"
            pos_hint: {"center_y": .5}
            spacing: "4dp"

            MDLabel:
                text: root.title
                font_style: "Subtitle2"
                bold: True
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#0F172A')
                shorten: True
                shorten_from: "right"

            MDLabel:
                text: root.date_label
                font_style: "Caption"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#64748B')

        # Amount + Status
        MDBoxLayout:
            orientation: "vertical"
            size_hint_x: None
            width: "120dp"
            spacing: "6dp"
            pos_hint: {"center_y": .5}

            MDLabel:
                text: root.amount_label
                font_style: "Subtitle1"
                bold: True
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#0F172A')
                halign: "right"

            # Status badge or action
            MDBoxLayout:
                orientation: "horizontal"
                spacing: "8dp"
                adaptive_width: True
                pos_hint: {"right": 1}

                MDCard:
                    size_hint: None, None 
                    height: "24dp"
                    width: self.minimum_width
                    radius: [12, 12, 12, 12]
                    md_bg_color: get_color_from_hex('#F0F9FF') if root.status_type == "owed" else get_color_from_hex('#FFF1F2')
                    padding: ["12dp", "4dp"]

                    MDLabel:
                        text: root.status_label
                        font_style: "Caption"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#0284C7') if root.status_type == "owed" else get_color_from_hex('#E11D48')
                        bold: True
                        adaptive_width: True

                # Action button for reminder or payment
                MDIconButton:
                    icon: "bell-outline" if root.status_type == "owed" else "credit-card-outline"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0284C7') if root.status_type == "owed" else get_color_from_hex('#E11D48')
                    size_hint: None, None
                    size: "24dp", "24dp"

<DashboardScreen>:
    # Main container with modern cream background
    MDFloatLayout:
        md_bg_color: get_color_from_hex('#FCF9F8')
        
        # --- SCROLLABLE CONTENT ---
        MDScrollView:
            pos_hint: {"top": 1}
            size_hint_y: 1
            
            MDBoxLayout:
                orientation: 'vertical'
                padding: ["24dp", "48dp", "24dp", "120dp"] # Extra bottom padding for nav
                spacing: "32dp"
                adaptive_height: True

                # 1. MODERN HEADER (SplitIt + Profile with status)
                MDBoxLayout:
                    orientation: 'horizontal'
                    adaptive_height: True
                    size_hint_y: None
                    height: "40dp"
                    
                    # Brand name + emoji
                    MDBoxLayout:
                        orientation: 'horizontal'
                        spacing: "8dp"
                        adaptive_width: True
                        
                        MDLabel:
                            text: "SplitIt"
                            font_style: "H5"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            valign: "center"
                            size_hint_x: None
                            width: self.texture_size[0]
                            
                        MDLabel:
                            text: "💸"
                            font_size: "20sp"
                            valign: "center"
                            size_hint_x: None
                            width: self.texture_size[0]
                    
                    Widget: # Spacer
                        
                    # Profile with online status indicator  
                    MDFloatLayout:
                        size_hint: None, None
                        size: "40dp", "40dp"
                        
                        # Profile avatar
                        MDCard:
                            size_hint: None, None
                            size: "40dp", "40dp" 
                            radius: [20, 20, 20, 20]
                            md_bg_color: get_color_from_hex('#FFF0EB')
                            
                            MDLabel:
                                text: "👩‍💼"
                                font_size: "24sp"
                                halign: "center"
                                valign: "center"
                        
                        # Online status dot
                        MDCard:
                            size_hint: None, None
                            size: "12dp", "12dp"
                            radius: [6, 6, 6, 6] 
                            md_bg_color: get_color_from_hex('#22C55E')
                            pos_hint: {"right": 1, "bottom": 0}
                            
                            # White border effect
                            MDCard:
                                size_hint: None, None
                                size: "8dp", "8dp"
                                radius: [4, 4, 4, 4]
                                md_bg_color: get_color_from_hex('#22C55E')
                                pos_hint: {"center_x": 0.5, "center_y": 0.5}

                # 2. GRADIENT HERO BANNER
                MDCard:
                    size_hint_y: None
                    height: "200dp"
                    radius: [32, 32, 32, 32]
                    md_bg_color: get_color_from_hex('#FFEDD5') # Fallback color
                    padding: ["25dp", "25dp", "25dp", "25dp"]
                    elevation: 4
                    
                    # Content overlay
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: "24dp"
                        
                        # Dashboard badge + Title
                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: "16dp"
                            adaptive_height: True
                            
                            # Orange badge
                            MDCard:
                                size_hint: None, None
                                width: "90dp"
                                height: "24dp"
                                radius: [12, 12, 12, 12]
                                md_bg_color: get_color_from_hex('#FFFFFF')
                                opacity: 0.8
                                padding: ["12dp", "4dp"]
                                
                                MDLabel:
                                    text: "DASHBOARD"
                                    font_style: "Caption"
                                    bold: True
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#F45925')
                                    halign: "center"
                                    adaptive_width: True
                            
                            # Main heading
                            MDLabel:
                                text: "Ready to split\nthe bill?"
                                font_style: "H4"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: get_color_from_hex('#0F172A')
                                valign: "top"
                                adaptive_height: True
                        
                        # CTA Button
                        MDCard:
                            size_hint: None, None
                            size: "200dp", "48dp"
                            radius: [24, 24, 24, 24]
                            md_bg_color: get_color_from_hex('#F45925')
                            elevation: 2
                            ripple_behavior: True
                            on_release: root.go_to_new_split()
                            
                            MDBoxLayout:
                                orientation: "horizontal"
                                spacing: "8dp"
                                
                                MDIcon:
                                    icon: "plus-circle-outline"
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#FFFFFF')
                                    size_hint_x: None
                                    width: "24dp"
                                    
                                MDLabel:
                                    text: "Create New Bill"
                                    font_style: "Subtitle2"
                                    bold: True
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#FFFFFF')
                                    halign: "center"
                                    valign: "center"

                # 3. ACTION BUTTONS (Scan Receipt + Add Friend)
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "16dp"
                    adaptive_height: True
                    size_hint_y: None
                    height: "102dp"
                    
                    # Scan Receipt Card  
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        size_hint_y: None
                        height: "102dp"
                        radius: [24, 24, 24, 24]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        padding: ["17dp", "17dp", "17dp", "17dp"]
                        elevation: 1
                        ripple_behavior: True
                        on_release: root.go_to_scan()
                        
                        # Green icon background
                        MDCard:
                            size_hint: None, None
                            size: "40dp", "40dp"
                            radius: [20, 20, 20, 20]
                            md_bg_color: get_color_from_hex('#DCFCE7')
                            
                            MDIcon:
                                icon: "camera-outline"
                                theme_text_color: "Custom"
                                text_color: get_color_from_hex('#16A34A')
                                pos_hint: {"center_x": .5, "center_y": .5}
                                
                        MDLabel:
                            text: "Scan Receipt"
                            font_style: "Subtitle2"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            adaptive_height: True
                            
                    # Add Friend Card
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        size_hint_y: None
                        height: "102dp"
                        radius: [24, 24, 24, 24]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        padding: ["17dp", "17dp", "17dp", "17dp"]
                        elevation: 1
                        ripple_behavior: True
                        on_release: root.go_to_add_friend()
                        
                        # Blue icon background
                        MDCard:
                            size_hint: None, None
                            size: "40dp", "40dp"
                            radius: [20, 20, 20, 20]
                            md_bg_color: get_color_from_hex('#DBEAFE')
                            
                            MDIcon:
                                icon: "account-multiple-plus-outline"
                                theme_text_color: "Custom"
                                text_color: get_color_from_hex('#2563EB')
                                pos_hint: {"center_x": .5, "center_y": .5}
                                
                        MDLabel:
                            text: "Add Friend"
                            font_style: "Subtitle2"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            adaptive_height: True

                # 4. BALANCE SUMMARY SECTION
                MDLabel:
                    text: "Balance Summary"
                    font_style: "Subtitle1"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0F172A')
                    adaptive_height: True
                    
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "16dp"
                    adaptive_height: True
                    size_hint_y: None
                    height: "142dp"
                    
                    # YOU OWE Card (Pink/Red)
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        padding: ["21dp", "21dp", "21dp", "21dp"]
                        size_hint_y: None
                        height: "142dp"
                        radius: [32, 32, 32, 32]
                        md_bg_color: get_color_from_hex('#FFF1F2')
                        elevation: 0
                        
                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: "12dp"
                            
                            # Amount section
                            MDBoxLayout:
                                orientation: "vertical"
                                adaptive_height: True
                                
                                MDLabel:
                                    text: "YOU OWE"
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#FB7185')
                                    font_style: "Caption"
                                    bold: True
                                    adaptive_height: True
                                    
                                MDLabel:
                                    text: f"฿{root.total_owed:.0f}"
                                    theme_text_color: "Custom" 
                                    text_color: get_color_from_hex('#E11D48')
                                    font_style: "H5"
                                    bold: True
                                    adaptive_height: True
                            
                            # Pay All Button
                            MDCard:
                                size_hint_y: None
                                height: "32dp"
                                radius: [16, 16, 16, 16]
                                md_bg_color: get_color_from_hex('#F43F5E')
                                elevation: 1
                                ripple_behavior: True
                                
                                MDLabel:
                                    text: "Pay All"
                                    font_style: "Caption"
                                    bold: True
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#FFFFFF')
                                    halign: "center"
                                    valign: "center"
                    
                    # OWED TO YOU Card (Blue) 
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        padding: ["21dp", "21dp", "21dp", "21dp"]
                        size_hint_y: None
                        height: "142dp"
                        radius: [32, 32, 32, 32]
                        md_bg_color: get_color_from_hex('#F0F9FF')
                        elevation: 0
                        
                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: "12dp"
                            
                            # Amount section
                            MDBoxLayout:
                                orientation: "vertical"
                                adaptive_height: True
                                
                                MDLabel:
                                    text: "OWED TO YOU"
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#38BDF8')
                                    font_style: "Caption"
                                    bold: True
                                    adaptive_height: True
                                    
                                MDLabel:
                                    text: f"฿{root.total_owe_me:.0f}"
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#0284C7')
                                    font_style: "H5"
                                    bold: True 
                                    adaptive_height: True
                            
                            # Remind All Button
                            MDCard:
                                size_hint_y: None
                                height: "32dp"
                                radius: [16, 16, 16, 16]
                                md_bg_color: get_color_from_hex('#0EA5E9')
                                elevation: 1
                                ripple_behavior: True
                                
                                MDLabel:
                                    text: "Remind All"
                                    font_style: "Caption"
                                    bold: True
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#FFFFFF')
                                    halign: "center"
                                    valign: "center"

                # 5. RECENT SPLITS SECTION
                MDBoxLayout:
                    orientation: "horizontal"
                    adaptive_height: True
                    
                    MDLabel:
                        text: "Recent Splits"
                        font_style: "Subtitle1"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#0F172A')
                        adaptive_height: True
                        
                    Widget: # Spacer
                    
                    MDLabel:
                        text: "View All"
                        font_style: "Subtitle2"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#F45925')
                        adaptive_height: True
                        size_hint_x: None
                        width: self.texture_size[0]

                # Empty state message
                MDLabel:
                    text: "ยังไม่มีบิลแชร์ — กด Create New Bill เพื่อเริ่ม!"
                    font_style: "Caption"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#9CA3AF')
                    halign: "center"
                    adaptive_height: True
                    opacity: 1 if len(root.recent_splits) == 0 else 0
                    size_hint_y: None
                    height: "40dp" if len(root.recent_splits) == 0 else "0dp"

                # Recent splits list
                RecycleView:
                    id: recent_splits_rv
                    data: root.recent_splits
                    viewclass: "RecentSplitItem"
                    size_hint_y: None
                    height: self.minimum_height

                    RecycleBoxLayout:
                        orientation: "vertical"
                        spacing: "12dp"
                        padding: ["0dp", "0dp", "0dp", "0dp"]
                        default_size: None, "80dp"
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height

        # --- FLOATING BOTTOM NAVIGATION ---
        MDCard:
            size_hint: None, None
            size: "400dp", "64dp"
            radius: [32, 32, 32, 32]
            md_bg_color: get_color_from_hex('#FFFFFF')
            opacity: 0.95
            pos_hint: {"center_x": .5, "y": .02}
            elevation: 8
            padding: ["25dp", "13dp", "25dp", "13dp"]
            
            MDBoxLayout:
                orientation: 'horizontal'
                
                # Home (Active - Orange)
                MDCard:
                    size_hint: None, None
                    size: "40dp", "40dp"
                    radius: [20, 20, 20, 20]
                    md_bg_color: get_color_from_hex('#F45925')
                    opacity: 0.1
                    
                    MDIcon:
                        icon: "home"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#F45925')
                        pos_hint: {"center_x": .5, "center_y": .5}
                        
                Widget: # Spacer
                    
                # Friends 
                MDIconButton:
                    icon: "account-group-outline"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#94A3B8')
                    pos_hint: {"center_y": .5}
                    
                Widget: # Spacer
                
                # Settings
                MDIconButton:
                    icon: "cog-outline"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#94A3B8')
                    pos_hint: {"center_y": .5}
