#:import get_color_from_hex kivy.utils.get_color_from_hex

# ── RecycleView item widget สำหรับแต่ละบิลใน Dashboard ──────────────────────
<BillCardItem>:
    size_hint_y: None
    height: "72dp"
    radius: [20, 20, 20, 20]
    md_bg_color: get_color_from_hex('#FFFFFF')
    elevation: 0
    padding: ["16dp", "0dp", "16dp", "0dp"]
    ripple_behavior: True
    on_release: app.root.get_screen('dashboard').on_bill_selected(root.bill_id)

    MDBoxLayout:
        orientation: 'horizontal'
        spacing: "12dp"

        # Icon Container
        MDBoxLayout:
            size_hint: None, None
            size: "44dp", "44dp"
            pos_hint: {"center_y": .5}
            md_bg_color: get_color_from_hex('#F1F5F9')
            radius: [12, 12, 12, 12]
            
            MDIcon:
                icon: root.icon_name
                font_size: "24sp"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#475569')
                halign: "center"
                valign: "center"
                pos_hint: {"center_x": .5, "center_y": .5}

        # Title + date
        MDBoxLayout:
            orientation: 'vertical'
            spacing: "2dp"
            pos_hint: {"center_y": .5}

            MDLabel:
                text: root.title
                font_style: "Subtitle2"
                bold: True
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#0F172A')
                adaptive_height: True

            MDLabel:
                text: root.date_label
                font_style: "Caption"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#94A3B8')
                adaptive_height: True

        Widget:

        # Amount + status
        MDBoxLayout:
            orientation: 'vertical'
            size_hint_x: None
            width: "120dp"
            spacing: "2dp"
            pos_hint: {"center_y": .5}

            MDLabel:
                text: root.amount_label
                font_style: "Subtitle2"
                bold: True
                halign: "right"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#0F172A')
                adaptive_height: True

            MDLabel:
                text: root.status_label
                font_style: "Caption"
                bold: True
                halign: "right"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#16A34A') if root.status_type == 'owed' else get_color_from_hex('#E11D48')
                adaptive_height: True

<DashboardScreen>:
    MDFloatLayout:
        md_bg_color: get_color_from_hex('#FCF9F8')
        
        MDScrollView:
            pos_hint: {"top": 1}
            size_hint_y: 1
            
            MDBoxLayout:
                orientation: 'vertical'
                padding: ["24dp", "48dp", "24dp", "120dp"]
                spacing: "24dp"
                adaptive_height: True

                # ── Header ────────────────────────────────────────────────
                MDBoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: "44dp"
                    spacing: "6dp"
                    
                    MDLabel:
                        text: "SplitIt"
                        font_style: "H5"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#0F172A')
                        adaptive_size: True
                        pos_hint: {"center_y": .5}
                    
                    AnchorLayout:
                        size_hint_x: None
                        width: "24dp"
                        anchor_x: "center"
                        anchor_y: "center"
                        MDIcon:
                            icon: "wallet-outline"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#F45925')
                            font_size: "22sp"
                            adaptive_size: True
                        
                    Widget:
                        
                   

                # ── Hero section ──────────────────────────────────────────
                MDCard:
                    size_hint_y: None
                    height: "200dp"
                    radius: [32, 32, 32, 32]
                    md_bg_color: get_color_from_hex('#FFEDD5')
                    padding: ["25dp", "25dp", "25dp", "25dp"]
                    elevation: 0
                    
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: "24dp"
                        
                        MDLabel:
                            text: "Ready to split\nthe bill?"
                            font_style: "H4"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            adaptive_height: True
                        
                        MDCard:
                            size_hint_x: 1
                            size_hint_y: None
                            height: "48dp"
                            radius: [24, 24, 24, 24]
                            md_bg_color: get_color_from_hex('#F45925')
                            elevation: 0
                            ripple_behavior: True
                            on_release: root.go_to_new_split()
                            
                            MDLabel:
                                text: "Create New Bill"
                                font_style: "Subtitle2"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: get_color_from_hex('#FFFFFF')
                                halign: "center"
                                valign: "center"

                # ── Action buttons ────────────────────────────────────────
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "16dp"
                    size_hint_y: None
                    height: "110dp"
                    
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        size_hint_y: None
                        height: "110dp"
                        radius: [24, 24, 24, 24]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        padding: ["12dp", "20dp", "12dp", "16dp"]
                        spacing: "10dp"
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.go_to_scan()
                        
                        Widget:

                        MDIcon:
                            icon: "camera-outline"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#16A34A')
                            font_size: "32sp"
                            halign: "center"
                            size_hint_y: None
                            height: "36dp"
                            pos_hint: {"center_x": .5, "center_y": .5}
                                
                        MDLabel:
                            text: "Scan Receipt"
                            font_style: "Subtitle2"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            halign: "center"
                            size_hint_y: None
                            height: "20dp"
                            
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        size_hint_y: None
                        height: "110dp"
                        radius: [24, 24, 24, 24]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        padding: ["12dp", "20dp", "12dp", "16dp"]
                        spacing: "10dp"
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.go_to_add_friend()
                        
                        Widget:

                        MDIcon:
                            pos_hint: {"center_x": .5, "center_y": .5}
                            icon: "account-multiple-plus-outline"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#2563EB')
                            font_size: "32sp"
                            halign: "center"
                            size_hint_y: None
                            height: "36dp"
                                
                        MDLabel:
                            text: "Add Friend"
                            font_style: "Subtitle2"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0F172A')
                            halign: "center"
                            size_hint_y: None
                            height: "20dp"

                # ── Balance summary ───────────────────────────────────────
                MDLabel:
                    text: "Balance Summary"
                    font_style: "Subtitle1"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0F172A')
                    adaptive_height: True
                    
                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "16dp"
                    size_hint_y: None
                    height: "130dp"
                    
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        padding: ["20dp", "16dp", "20dp", "16dp"]
                        size_hint_y: None
                        height: "130dp"
                        radius: [28, 28, 28, 28]
                        md_bg_color: get_color_from_hex('#FFF1F2')
                        elevation: 0
                        spacing: "6dp"
                        
                        MDBoxLayout:
                            orientation: 'horizontal'
                            size_hint_y: None
                            height: "24dp"
                            spacing: "4dp"
                            
                            AnchorLayout:
                                size_hint_x: None
                                width: "22dp"
                                anchor_x: "center"
                                anchor_y: "center"
                                MDIcon:
                                    icon: "bank-transfer-out"
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#FB7185')
                                    font_size: "18sp"
                                    adaptive_size: True

                            MDLabel:
                                text: "YOU OWE"
                                theme_text_color: "Custom"
                                text_color: get_color_from_hex('#FB7185')
                                font_style: "Caption"
                                bold: True
                                adaptive_height: True
                                pos_hint: {"center_y": .5}
                            
                        Widget:
                            
                        MDLabel:
                            text: "฿{:,.2f}".format(root.total_owed)
                            theme_text_color: "Custom" 
                            text_color: get_color_from_hex('#E11D48')
                            font_style: "H5"
                            bold: True
                            adaptive_height: True
                    
                    MDCard:
                        orientation: "vertical"
                        size_hint_x: 0.5
                        padding: ["20dp", "16dp", "20dp", "16dp"]
                        size_hint_y: None
                        height: "130dp"
                        radius: [28, 28, 28, 28]
                        md_bg_color: get_color_from_hex('#F0F9FF')
                        elevation: 0
                        spacing: "6dp"
                        
                        MDBoxLayout:
                            orientation: 'horizontal'
                            size_hint_y: None
                            height: "24dp"
                            spacing: "4dp"

                            AnchorLayout:
                                size_hint_x: None
                                width: "22dp"
                                anchor_x: "center"
                                anchor_y: "center"
                                MDIcon:
                                    icon: "bank-transfer-in"
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#38BDF8')
                                    font_size: "18sp"
                                    adaptive_size: True

                            MDLabel:
                                text: "OWED TO YOU"
                                theme_text_color: "Custom"
                                text_color: get_color_from_hex('#38BDF8')
                                font_style: "Caption"
                                bold: True
                                adaptive_height: True
                                pos_hint: {"center_y": .5}
                            
                        Widget:
                            
                        MDLabel:
                            text: "฿{:,.2f}".format(root.total_owe_me)
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0284C7')
                            font_style: "H5"
                            bold: True 
                            adaptive_height: True

                # ── Recent splits ─────────────────────────────────────────
                MDLabel:
                    text: "Recent Splits"
                    font_style: "Subtitle1"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0F172A')
                    adaptive_height: True

                # Empty state
                MDLabel:
                    text: "ยังไม่มีบิล — กด Scan หรือ Create New Bill เพื่อเริ่ม!"
                    font_style: "Caption"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#BDBDBD')
                    halign: "center"
                    adaptive_height: True
                    opacity: 1 if len(root.recent_splits) == 0 else 0
                    size_hint_y: None
                    height: "40dp" if len(root.recent_splits) == 0 else "0dp"

                # Dynamic Bill List
                RecycleView:
                    id: recent_splits_rv
                    data: root.recent_splits
                    viewclass: "BillCardItem"
                    size_hint_y: None
                    height: rv_layout.minimum_height

                    RecycleBoxLayout:
                        id: rv_layout
                        orientation: "vertical"
                        spacing: "10dp"
                        padding: ["0dp", "0dp", "0dp", "0dp"]
                        default_size: None, "72dp"
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height

        # Bottom navigation component
        BottomNav:
            active_tab: 'home'
