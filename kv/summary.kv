#:import get_color_from_hex kivy.utils.get_color_from_hex

<SummaryScreen>:
    MDFloatLayout:
        md_bg_color: get_color_from_hex('#F6F8F7')

        MDScrollView:
            pos_hint: {"top": 1}
            size_hint_y: 1

            MDBoxLayout:
                orientation: 'vertical'
                padding: ["20dp", "48dp", "20dp", "120dp"]
                spacing: "20dp"
                adaptive_height: True

                # Header
                MDBoxLayout:
                    orientation: 'horizontal'
                    adaptive_height: True
                    size_hint_y: None
                    height: "48dp"

                    MDCard:
                        size_hint: None, None
                        size: "40dp", "40dp"
                        radius: [20, 20, 20, 20]
                        md_bg_color: get_color_from_hex('#FFFFFF')
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.go_back()

                        MDIcon:
                            icon: "arrow-left"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0E1B14')
                            halign: "center"

                    Widget:

                    MDLabel:
                        text: "Summary"
                        font_style: "H6"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#0E1B14')
                        halign: "center"
                        size_hint_x: None
                        width: "140dp"

                    Widget:

                    Widget:
                        size_hint_x: None
                        width: "40dp"

                # Receipt card
                MDCard:
                    size_hint_y: None
                    height: "280dp"
                    radius: [24, 24, 24, 24]
                    md_bg_color: get_color_from_hex('#FECDD3')
                    elevation: 0
                    padding: ["24dp", "24dp", "24dp", "24dp"]

                    MDBoxLayout:
                        orientation: 'vertical'
                        spacing: "8dp"

                        MDBoxLayout:
                            orientation: 'horizontal'
                            adaptive_height: True
                            size_hint_y: None
                            height: "32dp"

                            MDCard:
                                size_hint: None, None
                                size: "128dp", "28dp"
                                radius: [14, 14, 14, 14]
                                md_bg_color: get_color_from_hex('#FFFFFF')
                                elevation: 0

                                MDLabel:
                                    id: receipt_number_label
                                    text: "RECEIPT #001"
                                    font_style: "Caption"
                                    bold: True
                                    theme_text_color: "Custom"
                                    text_color: get_color_from_hex('#F43F5E')
                                    halign: "center"

                            Widget:

                            MDIcon:
                                icon: "receipt"
                                theme_text_color: "Custom"
                                text_color: get_color_from_hex('#F43F5E')
                                size_hint_x: None
                                width: "28dp"

                        Widget:

                        MDLabel:
                            text: "Here is the damage!"
                            font_style: "Body1"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0E1B14')
                            adaptive_height: True

                        MDLabel:
                            id: bill_title_label
                            text: "Sushi Buffet"
                            font_style: "H5"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0E1B14')
                            adaptive_height: True

                        MDLabel:
                            id: bill_total_label
                            text: "0"
                            font_style: "H4"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0E1B14')
                            adaptive_height: True

                # Breakdown heading
                MDBoxLayout:
                    orientation: 'horizontal'
                    adaptive_height: True
                    size_hint_y: None
                    height: "32dp"

                    MDLabel:
                        text: "Breakdown"
                        font_style: "H6"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#0E1B14')
                        adaptive_height: True

                    Widget:

                    MDCard:
                        size_hint: None, None
                        size: "80dp", "28dp"
                        radius: [6, 6, 6, 6]
                        md_bg_color: get_color_from_hex('#D1FAE5')
                        elevation: 0

                        MDLabel:
                            id: people_count_label
                            text: "0 People"
                            font_style: "Caption"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#065F46')
                            halign: "center"

                # Breakdown list
                MDBoxLayout:
                    id: breakdown_list
                    orientation: 'vertical'
                    adaptive_height: True
                    spacing: "8dp"

        # Bottom buttons
        MDBoxLayout:
            orientation: 'vertical'
            size_hint: 1, None
            height: "130dp"
            pos_hint: {"bottom": 1, "x": 0}
            md_bg_color: get_color_from_hex('#F6F8F7')
            padding: ["20dp", "8dp", "20dp", "8dp"]
            spacing: "8dp"

            MDCard:
                size_hint_y: None
                height: "56dp"
                radius: [28, 28, 28, 28]
                md_bg_color: get_color_from_hex('#50C878')
                elevation: 0
                ripple_behavior: True
                on_release: root.on_copy_clipboard()

                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "8dp"
                    padding: ["20dp", "0dp", "20dp", "0dp"]

                    MDIcon:
                        icon: "content-copy"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#FFFFFF')
                        size_hint_x: None
                        width: "24dp"

                    MDLabel:
                        text: "Copy to Clipboard"
                        font_style: "Subtitle1"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex('#FFFFFF')
                        halign: "center"
                        adaptive_height: True

            MDLabel:
                text: "Finish & Go to Home"
                font_style: "Subtitle2"
                theme_text_color: "Custom"
                text_color: get_color_from_hex('#4E9773')
                halign: "center"
                adaptive_height: True
                on_touch_down: root.on_save_and_finish()
