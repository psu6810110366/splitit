#:import get_color_from_hex kivy.utils.get_color_from_hex

<FriendsScreen>:
    MDFloatLayout:
        md_bg_color: get_color_from_hex('#F6F8F7')

        MDScrollView:
            pos_hint: {"top": 1}
            size_hint_y: 1

            MDBoxLayout:
                orientation: 'vertical'
                padding: ["20dp", "48dp", "20dp", "100dp"]
                spacing: "20dp"
                adaptive_height: True

                # Header
                MDLabel:
                    text: "Friends"
                    font_style: "H5"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#0E1B14')
                    adaptive_height: True

                MDLabel:
                    text: "People you split bills with"
                    font_style: "Body2"
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex('#6B7280')
                    adaptive_height: True

                # Placeholder
                MDCard:
                    size_hint_y: None
                    height: "200dp"
                    radius: [24, 24, 24, 24]
                    md_bg_color: get_color_from_hex('#FFFFFF')
                    elevation: 0
                    padding: ["24dp", "24dp", "24dp", "24dp"]

                    MDBoxLayout:
                        orientation: 'vertical'
                        spacing: "12dp"

                        MDLabel:
                            text: "👥"
                            font_size: "48sp"
                            halign: "center"
                            adaptive_height: True

                        MDLabel:
                            text: "No friends yet"
                            font_style: "Subtitle1"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#0E1B14')
                            halign: "center"
                            adaptive_height: True

                        MDLabel:
                            text: "Add friends when creating a new split"
                            font_style: "Body2"
                            theme_text_color: "Custom"
                            text_color: get_color_from_hex('#6B7280')
                            halign: "center"
                            adaptive_height: True

        # Bottom navigation
        BottomNav:
            active_tab: 'friends'
